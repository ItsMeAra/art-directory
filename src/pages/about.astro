---
import SiteLayout from '../layouts/SiteLayout.astro';
import DirectoryFaq from '../components/DirectoryFaq.astro';
import {
  ABOUT_AUTHOR_IMAGE,
  ABOUT_AUTHOR_IMAGE_ALT,
  ABOUT_FAQ_ENTRIES,
  ABOUT_HERO,
  AUTHOR_LINKTREE_URL,
  AUTHOR_SCHEMA_NAME,
  WHO_MADE_THIS,
} from '../lib/about-content';
import { buildAboutPageJsonLd, jsonLdToScriptContent } from '../lib/schema-org';

const githubRepoBase =
  import.meta.env.PUBLIC_GITHUB_REPO_URL ?? 'https://github.com/ItsMeAra/art-directory';

const pageTitle = 'About — Hunt & Haul';
const pageDescription =
  'What Hunt & Haul is, who built it, how we curate listings, and answers about designer toys, sofubi, and collecting.';

const authorImageUrl =
  Astro.site != null ? new URL(ABOUT_AUTHOR_IMAGE, Astro.site).href : ABOUT_AUTHOR_IMAGE;

const aboutJsonLd =
  Astro.site != null
    ? buildAboutPageJsonLd(
        Astro.site,
        pageTitle,
        pageDescription,
        ABOUT_FAQ_ENTRIES,
        authorImageUrl,
        { name: AUTHOR_SCHEMA_NAME, sameAs: AUTHOR_LINKTREE_URL },
      )
    : null;
---

<SiteLayout title={pageTitle} description={pageDescription} githubRepoBase={githubRepoBase}>
  {aboutJsonLd && (
    <script
      is:inline
      type="application/ld+json"
      slot="head"
      set:html={jsonLdToScriptContent(aboutJsonLd)}
    />
  )}

  <!-- Hero: full-bleed gradient + soft glow -->
  <div
    class="relative w-full overflow-hidden border-b border-violet-200/80 dark:border-violet-900/50 bg-linear-to-br from-violet-100 via-white to-fuchsia-50 dark:from-violet-950/80 dark:via-zinc-950 dark:to-fuchsia-950/25"
  >
    <div
      class="pointer-events-none absolute -top-28 -right-20 h-72 w-72 rounded-full bg-violet-400/25 blur-3xl dark:bg-violet-500/15"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute -bottom-20 -left-16 h-56 w-56 rounded-full bg-fuchsia-400/20 blur-3xl dark:bg-fuchsia-600/10"
      aria-hidden="true"
    />
    <div class="relative max-w-6xl mx-auto px-4 py-10 sm:px-6 sm:py-14 lg:px-8 lg:py-20">
      <nav class="text-sm text-violet-900/70 dark:text-violet-200/80 mb-8 lg:mb-10" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
          <li>
            <a href="/" class="text-violet-700 dark:text-violet-300 hover:underline font-medium">{`Hunt & Haul`}</a>
          </li>
          <li aria-hidden="true" class="text-violet-300/80 dark:text-violet-600">/</li>
          <li class="text-violet-950 dark:text-zinc-100 font-medium">About</li>
        </ol>
      </nav>

      <header class="w-full rounded-2xl border border-violet-200/70 dark:border-violet-800/60 bg-white/70 dark:bg-zinc-900/50 px-6 py-8 sm:px-8 sm:py-10 shadow-lg shadow-violet-900/5 dark:shadow-black/40 backdrop-blur-sm">
        <p class="text-xs font-semibold uppercase tracking-widest text-violet-600 dark:text-violet-400">
          About the project
        </p>
        <h1
          class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-zinc-50 tracking-tight text-balance"
        >
          {ABOUT_HERO.title}
        </h1>
        <p class="mt-5 text-lg sm:text-xl text-violet-800 dark:text-violet-200 font-medium leading-snug text-balance">
          {ABOUT_HERO.lead}
        </p>
        <div class="mt-6 space-y-4 text-sm sm:text-base text-gray-700 dark:text-zinc-300 leading-relaxed">
          {ABOUT_HERO.paragraphs.map(p => (
            <p>{p}</p>
          ))}
        </div>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/"
            class="inline-flex items-center justify-center rounded-full bg-violet-600 px-5 py-2.5 text-sm font-semibold text-white shadow-md shadow-violet-900/20 hover:bg-violet-700 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2 dark:focus:ring-offset-zinc-900"
          >
            Browse the directory
          </a>
          <a
            href="/submit"
            class="inline-flex items-center justify-center rounded-full border border-violet-300 dark:border-violet-600 bg-white/80 dark:bg-zinc-900/80 px-5 py-2.5 text-sm font-semibold text-violet-800 dark:text-violet-200 hover:bg-violet-50 dark:hover:bg-zinc-800 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2 dark:focus:ring-offset-zinc-900"
          >
            Submit a listing
          </a>
        </div>
      </header>
    </div>
  </div>

  <!-- Who made this: light “card” band -->
  <section
    class="w-full bg-white dark:bg-zinc-900 border-b border-gray-200 dark:border-zinc-800"
    aria-labelledby="who-made-this-heading"
  >
    <div class="max-w-6xl mx-auto px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
      <div class="grid gap-10 lg:gap-14 lg:grid-cols-2 lg:items-center">
        <div class="min-w-0 order-2 lg:order-1">
          <h2
            id="who-made-this-heading"
            class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-zinc-100 tracking-tight"
          >
            {WHO_MADE_THIS.heading}
          </h2>
          <div class="mt-5 space-y-4 text-sm sm:text-base text-gray-600 dark:text-zinc-400 leading-relaxed">
            {WHO_MADE_THIS.paragraphs.map(p => (
              <p>{p}</p>
            ))}
          </div>
          <p class="mt-6">
            <a
              href={AUTHOR_LINKTREE_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full bg-violet-100 dark:bg-violet-950/80 px-4 py-2 text-sm font-semibold text-violet-800 dark:text-violet-200 hover:bg-violet-200/80 dark:hover:bg-violet-900/80 transition-colors"
            >
              {WHO_MADE_THIS.linkLabel}
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden>
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </p>
        </div>
        <div class="order-1 lg:order-2 w-full max-w-sm mx-auto lg:max-w-none lg:justify-self-end">
          <div
            class="rounded-2xl overflow-hidden border border-violet-200/80 dark:border-violet-800/50 shadow-xl shadow-violet-900/10 dark:shadow-black/50 ring-1 ring-black/5 dark:ring-white/10 bg-zinc-100 dark:bg-zinc-800 aspect-4/5"
          >
            <img
              src={ABOUT_AUTHOR_IMAGE}
              alt={ABOUT_AUTHOR_IMAGE_ALT}
              width="480"
              height="600"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ: alternate tinted band -->
  <div
    class="w-full bg-linear-to-b from-violet-50/90 to-gray-50 dark:from-violet-950/35 dark:to-zinc-950 border-t border-violet-100 dark:border-violet-900/40"
  >
    <div class="max-w-6xl mx-auto">
      <DirectoryFaq items={ABOUT_FAQ_ENTRIES} showHeading={true} tone="embed" />
    </div>
  </div>
</SiteLayout>
