---
import SiteLayout from '../layouts/SiteLayout.astro';
import SubmitListingForm from '../components/SubmitListingForm';
import { buildSubmitPageJsonLd, jsonLdToScriptContent } from '../lib/schema-org';

const githubRepoBase =
  import.meta.env.PUBLIC_GITHUB_REPO_URL ?? 'https://github.com/ItsMeAra/art-directory';

const pageDescription =
  'Suggest a gallery, shop, marketplace, or other spot for art and designer toys.';

const submitJsonLd =
  Astro.site != null ? buildSubmitPageJsonLd(Astro.site, pageDescription) : null;
---

<SiteLayout
  title="Submit a listing — Hunt & Haul"
  description={pageDescription}
  githubRepoBase={githubRepoBase}
>
  {submitJsonLd && (
    <script
      is:inline
      type="application/ld+json"
      slot="head"
      set:html={jsonLdToScriptContent(submitJsonLd)}
    />
  )}
  <div class="w-full max-w-lg mx-auto px-4 py-8 sm:px-6 lg:px-8">
    <nav class="text-sm text-gray-500 dark:text-zinc-400 mb-6" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
        <li>
          <a href="/" class="text-violet-600 dark:text-violet-400 hover:underline font-medium">{`Hunt & Haul`}</a>
        </li>
        <li aria-hidden="true" class="text-gray-300 dark:text-zinc-600">/</li>
        <li class="text-gray-700 dark:text-zinc-300">Submit a listing</li>
      </ol>
    </nav>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-zinc-100 tracking-tight">Submit a listing</h1>
    <p class="mt-2 text-sm text-gray-600 dark:text-zinc-400">
      Tell us about a place worth hunting down. Fields marked <span class="text-red-600 dark:text-red-400">*</span> are required.
    </p>
    <div class="mt-8">
      <SubmitListingForm client:load repoBase={githubRepoBase} />
    </div>
  </div>
</SiteLayout>
