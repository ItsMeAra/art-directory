---
import SiteLayout from '../layouts/SiteLayout.astro';
import SubmitListingForm from '../components/SubmitListingForm';
import { buildSubmitPageJsonLd, jsonLdToScriptContent } from '../lib/schema-org';

const githubRepoBase =
  import.meta.env.PUBLIC_GITHUB_REPO_URL ?? 'https://github.com/ItsMeAra/art-directory';

const pageDescription =
  'Suggest a gallery, shop, marketplace, or other spot for art and designer toys.';

const submitJsonLd =
  Astro.site != null ? buildSubmitPageJsonLd(Astro.site, pageDescription) : null;
---

<SiteLayout
  title="Submit a listing — Hunt & Haul"
  description={pageDescription}
  githubRepoBase={githubRepoBase}
>
  {submitJsonLd && (
    <script
      is:inline
      type="application/ld+json"
      slot="head"
      set:html={jsonLdToScriptContent(submitJsonLd)}
    />
  )}

  <div
    class="relative w-full flex-1 overflow-hidden border-b border-violet-200/80 dark:border-violet-900/50 bg-linear-to-br from-violet-100 via-white to-fuchsia-50 dark:from-violet-950/80 dark:via-zinc-950 dark:to-fuchsia-950/25"
  >
    <div
      class="pointer-events-none absolute -top-28 -right-20 h-72 w-72 rounded-full bg-violet-400/25 blur-3xl dark:bg-violet-500/15"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute top-40 -left-16 h-56 w-56 rounded-full bg-fuchsia-400/20 blur-3xl dark:bg-fuchsia-600/10"
      aria-hidden="true"
    />

    <div class="relative max-w-6xl mx-auto px-4 py-10 sm:px-6 sm:py-14 lg:px-8 lg:py-16">
      <nav class="text-sm text-violet-900/70 dark:text-violet-200/80 mb-8 lg:mb-10" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
          <li>
            <a href="/" class="text-violet-700 dark:text-violet-300 hover:underline font-medium">{`Hunt & Haul`}</a>
          </li>
          <li aria-hidden="true" class="text-violet-300/80 dark:text-violet-600">/</li>
          <li class="text-violet-950 dark:text-zinc-100 font-medium">Submit a listing</li>
        </ol>
      </nav>

      <div class="max-w-xl mx-auto">
        <div
          class="w-full rounded-2xl border border-violet-200/70 dark:border-violet-800/60 bg-white/70 dark:bg-zinc-900/50 px-6 py-8 sm:px-8 sm:py-10 shadow-lg shadow-violet-900/5 dark:shadow-black/40 backdrop-blur-sm"
        >
          <p class="text-xs font-semibold uppercase tracking-widest text-violet-600 dark:text-violet-400">
            Directory submissions
          </p>
          <h1 class="mt-3 text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 dark:text-zinc-50 tracking-tight text-balance">
            Submit a listing
          </h1>
          <p class="mt-4 text-sm sm:text-base text-gray-700 dark:text-zinc-300 leading-relaxed">
            Tell us about a place worth hunting down. Fields marked{' '}
            <span class="text-red-600 dark:text-red-400">*</span> are required.
          </p>
          <div class="mt-8">
            <SubmitListingForm client:load repoBase={githubRepoBase} />
          </div>
        </div>
      </div>
    </div>
  </div>
</SiteLayout>
