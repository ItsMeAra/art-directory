---
import SiteLayout from '../layouts/SiteLayout.astro';
import SubmitListingForm from '../components/SubmitListingForm';

const githubRepoBase =
  import.meta.env.PUBLIC_GITHUB_REPO_URL ?? 'https://github.com/ItsMeAra/art-directory';
---

<SiteLayout
  title="Submit a listing — Hunt & Haul"
  description="Suggest a gallery, shop, marketplace, or other spot for art and designer toys."
  githubRepoBase={githubRepoBase}
>
  <div class="w-full max-w-lg mx-auto px-4 py-8 sm:px-6 lg:px-8">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-zinc-100 tracking-tight">Submit a listing</h1>
    <p class="mt-2 text-sm text-gray-600 dark:text-zinc-400">
      Tell us about a place worth hunting down. Fields marked <span class="text-red-600 dark:text-red-400">*</span> are required.
    </p>
    <div class="mt-8">
      <SubmitListingForm client:load repoBase={githubRepoBase} />
    </div>
  </div>
</SiteLayout>
